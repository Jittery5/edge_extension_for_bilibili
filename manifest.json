{
  "manifest_version": 3,
  "name": "Bilibili 低粉过滤",
  "version": "1.1",
  "description": "屏蔽 B 站首页粉丝数不足 5 万的 UP 主视频",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.bilibili.com/*",
    "https://api.bilibili.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.bilibili.com/",
        "https://www.bilibili.com/?*",
        "https://www.bilibili.com/index.html"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
